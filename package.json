{
  "name": "gong-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing the Gong public REST API as tools",
  "type": "module",
  "bin": {
    "gong-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:local": "node --env-file=.env dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:local": "node --env-file=.env --import tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
