# Copy to `.env` and fill in. Do NOT put real secrets in this file — it is meant to be committed.
# Gong API credentials (Basic Auth: username=access key, password=secret)
GONG_ACCESS_KEY=your-access-key
GONG_ACCESS_SECRET=your-access-secret

# Optional: override API base URL (defaults to https://api.gong.io/v2).
# For tenant-specific hosts, keep the `/v2` suffix — tool paths are relative to this.
# GONG_API_BASE_URL=https://us-XXXXX.api.gong.io/v2

# Optional: scrub emails/phone numbers/personal URLs from transcript text AND from
# summarized tool output (participant emails, userEmailAddress, phoneNumber, etc.).
# REDACT_PII=false

# Optional: log level (debug|info|warn|error). Logs to stderr; credentials are never logged.
# LOG_LEVEL=info

# --- Security hardening (opt-in) ---

# Enable the generic gong_raw_request escape hatch. Default OFF — a compromised LLM
# that is tricked by poisoned transcript content cannot call arbitrary Gong endpoints
# unless the operator explicitly opts in.
# GONG_ALLOW_RAW_REQUEST=false

# Comma-separated path prefixes the raw tool is allowed to hit (when enabled).
# Defaults to a safe set; override to extend or restrict.
# GONG_RAW_REQUEST_ALLOWED_PREFIXES=/calls,/users,/stats,/crm,/library,/workspaces,/settings

# Include Gong's full error body in tool error results. Off by default — the response
# body can echo the submitted payload or include unrelated tenant data.
# GONG_INCLUDE_ERROR_BODY=false

# Size caps to prevent memory blow-ups on pathological responses.
# GONG_MAX_RESPONSE_BYTES=8388608      # 8 MB, cap on Gong response buffering
# GONG_MAX_TOOL_OUTPUT_BYTES=1048576   # 1 MB, cap on what we serialize back to the LLM
